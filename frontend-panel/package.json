{
	"name": "asterdrive-panel",
	"private": true,
	"version": "0.2.0",
	"type": "module",
	"scripts": {
		"extract:pdfjs-cmaps": "node ./scripts/extract-pdfjs-cmaps.mjs",
		"predev": "bun run extract:pdfjs-cmaps",
		"dev": "vite",
		"prebuild": "bun run extract:pdfjs-cmaps",
		"build": "tsgo -b && vite build",
		"generate-api": "openapi-typescript ./generated/openapi.json -o ./src/services/api.generated.ts",
		"check": "tsgo -b && biome check .",
		"check:fix": "biome check --write .",
		"format": "biome format --write .",
		"preview": "vite preview",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:asterdrive": "playwright test e2e",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@babel/plugin-transform-modules-systemjs": "7.29.4",
		"@base-ui/react": "^1.5.0",
		"@fontsource-variable/geist": "^5.2.9",
		"@hono/node-server": "2.0.3",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/react-virtual": "^3.13.25",
		"artplayer": "^5.4.0",
		"axios": "^1.16.1",
		"brace-expansion": "5.0.6",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"fast-uri": "3.1.2",
		"hono": "4.12.22",
		"i18next": "^26.2.0",
		"ip-address": "10.2.0",
		"music-metadata": "^11.12.3",
		"papaparse": "^5.5.3",
		"picomatch": "4.0.4",
		"prism-react-renderer": "^2.4.1",
		"prismjs": "^1.30.0",
		"qrcode": "^1.5.4",
		"react": "^19.2.6",
		"react-devicons": "^2.16.2",
		"react-dom": "^19.2.6",
		"react-i18next": "^17.0.8",
		"react-icons": "^5.6.0",
		"react-image-crop": "^11.0.10",
		"react-markdown": "^10.1.0",
		"react-pdf": "^10.4.1",
		"react-router-dom": "^7.15.1",
		"recharts": "^3.8.1",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"shadcn": "^4.8.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"xml-formatter": "^3.7.0",
		"zod": "^4.4.3",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@playwright/test": "^1.60.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.9.1",
		"@types/papaparse": "^5.5.2",
		"@types/qrcode": "^1.5.6",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260523.1",
