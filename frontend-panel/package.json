		"jsdom": "^29.1.1",
		"msw": "^2.14.6",
		"openapi-typescript": "^7.13.0",
		"vite": "^8.0.14",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.7"
	},
	"overrides": {
		"@babel/plugin-transform-modules-systemjs": "7.29.4",
		"@hono/node-server": "2.0.3",
		"brace-expansion": "5.0.6",
		"fast-uri": "3.1.2",
		"hono": "4.12.22",
		"ip-address": "10.2.0",
		"picomatch": "4.0.4",
		"react": "^19.2.6"
	}
}
